{
  "manifest_version": 3,
  "name": "LayoutPick",
  "version": "0.1.0",
  "description": "Pick any element on a page and send it to the active Claude Code session via LayoutPick.",
  "key": "",
  "permissions": ["tabs", "scripting", "nativeMessaging"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "service-worker.js", "type": "module" },
  "action": { "default_title": "Toggle UI picker (Alt+S)" },
  "commands": {
    "toggle-picker": {
      "suggested_key": { "default": "Alt+S" },
      "description": "Toggle the element picker"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-main.bundle.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content-relay.js"],
      "world": "ISOLATED",
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
